<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Nebasun">

        <activity
            android:name="com.nebasun.game.activities.SplashActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.nebasun.game.activities.MainActivity"
            android:screenOrientation="portrait" />

        <activity
            android:name="com.nebasun.game.activities.LevelSelectActivity"
            android:screenOrientation="portrait" />

        <activity
            android:name="com.nebasun.game.activities.GameActivity"
            android:screenOrientation="portrait" />

        <activity
            android:name="com.nebasun.game.activities.ProfileActivity"
            android:screenOrientation="portrait" />

        <activity
            android:name="com.nebasun.game.activities.MultiplayerActivity"
            android:screenOrientation="portrait" />

    </application>

</manifest>
